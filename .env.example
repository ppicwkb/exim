# Salin file ini menjadi .env dan isi dengan nilai Anda
# cp .env.example .env

# Google OAuth Client ID dari Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google Drive Folder ID tempat file disimpan
VITE_GOOGLE_FOLDER_ID=your-folder-id

# Google Sheets ID tempat metadata disimpan
VITE_GOOGLE_SHEET_ID=your-sheet-id
